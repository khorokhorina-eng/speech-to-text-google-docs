{
  "name": "__MSG_appName__",
  "description": "__MSG_shortDesc__",
  "default_locale": "en",
  "version": "1.2.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Speech to Text Google Docs",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": ["storage", "scripting", "debugger"],
  "optional_permissions": ["activeTab"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://voicetext.world/*",
    "https://www.voicetext.world/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
