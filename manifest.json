{
  "name": "Speech to Text for Google Docs",
  "description": "Dictate into Google Docs with speech recognition and paid access controls.",
  "version": "1.0.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Speech to Text for Google Docs",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*/*.pdf",
    "*://*/*.PDF",
    "file:///*",
    "https://pdftext2speech.com/*",
    "https://www.pdftext2speech.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.PDF",
        "file:///*"
      ],
      "js": [
        "vendor/pdfjs/pdf.min.js",
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdfjs/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
